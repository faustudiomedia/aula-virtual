# ──────────────────────────────────────────────────────
# MAVIC – Variables de entorno
# Copiá este archivo como .env.local y completá los valores
# ──────────────────────────────────────────────────────

# Supabase – obtenelos en https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Service Role Key – para invitaciones de admin (NUNCA expongas esta en el frontend)
# Obtenela en: https://supabase.com/dashboard/project/_/settings/api → service_role
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# ──────────────────────────────────────────────────────
# Pasos para empezar:
#
# 1. Cloná el repo y copiá este archivo:
#    cp .env.local.example .env.local
#
# 2. Creá un proyecto en https://supabase.com y pegá las keys
#
# 3. Ejecutá las migraciones en orden desde el SQL Editor de Supabase:
#    supabase/migrations/001_initial_schema.sql
#    supabase/migrations/002_rls_and_storage.sql
#    supabase/migrations/003_advanced_features.sql
#
# 4. Instalá dependencias:
#    npm install
#
# 5. Levantá el servidor:
#    npm run dev  →  http://localhost:3000
# ──────────────────────────────────────────────────────
